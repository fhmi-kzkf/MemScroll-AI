generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaperSourceType {
  api
  pdf_upload
}

enum PaperStatus {
  pending
  processing
  completed
  failed
}

enum ConceptStatus {
  active
  archived
  pinned
}

enum MemoryDiffOperationType {
  promoted
  archived
  pinned
  unpinned
}

model User {
  id             String           @id @default(uuid())
  projects       Project[]
  synthesisNotes SynthesisNote[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Project {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  name           String
  papers         Paper[]
  concepts       Concept[]
  synthesisNotes SynthesisNote[]
  memoryDiffs    MemoryDiff[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Paper {
  id              String             @id @default(uuid())
  projectId       String
  project         Project            @relation(fields: [projectId], references: [id])
  title           String
  authors         Json
  abstract        String?            @db.Text
  sourceType      PaperSourceType
  rawContent      String?            @db.Text
  status          PaperStatus        @default(pending)
  paperConcepts   PaperConceptMap[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Concept {
  id              String             @id @default(uuid())
  projectId       String
  project         Project            @relation(fields: [projectId], references: [id])
  name            String
  description     String?            @db.Text
  embedding       Unsupported("vector(1024)")
  recencyScore    Float              @default(0.0)
  frequencyScore  Float              @default(0.0)
  importanceScore Float              @default(0.0)
  decayScore      Float              @default(0.0)
  status          ConceptStatus      @default(active)
  paperConcepts   PaperConceptMap[]
  synthesisNotes  SynthesisNote[]
  memoryDiffs     MemoryDiff[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PaperConceptMap {
  id             String   @id @default(uuid())
  paperId        String
  paper          Paper    @relation(fields: [paperId], references: [id])
  conceptId      String
  concept        Concept  @relation(fields: [conceptId], references: [id])
  contextSnippet String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([paperId, conceptId])
}

model SynthesisNote {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  conceptId  String?
  concept    Concept?  @relation(fields: [conceptId], references: [id])
  content    String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model MemoryDiff {
  id            String                  @id @default(uuid())
  projectId     String
  project       Project                 @relation(fields: [projectId], references: [id])
  sessionId     String
  operationType MemoryDiffOperationType
  conceptId     String
  concept       Concept                 @relation(fields: [conceptId], references: [id])
  reasoning     String?                 @db.Text
  createdAt     DateTime                @default(now())
}